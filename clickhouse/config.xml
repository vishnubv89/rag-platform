<clickhouse>
  <!-- Enable built-in ClickHouse Keeper (ZooKeeper replacement) for single-node -->
  <keeper_server>
    <tcp_port>9181</tcp_port>
    <server_id>1</server_id>
    <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
    <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
    <raft_configuration>
      <server>
        <id>1</id>
        <hostname>localhost</hostname>
        <port>9444</port>
      </server>
    </raft_configuration>
  </keeper_server>

  <!-- Point ClickHouse at the local Keeper -->
  <zookeeper>
    <node>
      <host>localhost</host>
      <port>9181</port>
    </node>
  </zookeeper>

  <!-- Single-node "default" cluster so ON CLUSTER queries work -->
  <remote_servers>
    <default>
      <shard>
        <replica>
          <host>clickhouse</host>
          <port>9000</port>
          <user>clickhouse</user>
          <password>clickhouse</password>
        </replica>
      </shard>
    </default>
  </remote_servers>

  <!-- Required macros for ReplicatedMergeTree -->
  <macros>
    <shard>01</shard>
    <replica>01</replica>
  </macros>
</clickhouse>
