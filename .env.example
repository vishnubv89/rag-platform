# LLM provider: "gemini" or "anthropic"
LLM_PROVIDER=gemini

# Gemini — always required for embeddings
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic — set LLM_PROVIDER=anthropic and provide this key to use Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# NVIDIA NIM (or any OpenAI-compatible API) — set LLM_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_BASE_URL defaults to https://integrate.api.nvidia.com/v1
# Override to point at OpenAI, Groq, Together AI, Ollama, etc.

ADMIN_SECRET_KEY=change-me

# Zitadel SSO (optional — leave empty to use local password login only)
# After starting Zitadel, set this to the issuer shown in the discovery doc:
#   curl http://localhost:8088/.well-known/openid-configuration | jq .issuer
# Typically: http://localhost:8088 (dev) or https://auth.yourdomain.com (prod)
ZITADEL_ISSUER=
