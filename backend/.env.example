DATABASE_URL=postgresql://rag:rag_secret@localhost:5432/rag_db

# LLM provider: "gemini" or "anthropic"
LLM_PROVIDER=gemini

# Gemini (required for embeddings; also for LLM when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
